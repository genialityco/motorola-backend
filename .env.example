PORT=3001

# ─── Modo emulador (desarrollo local) ────────────────────────────────────────
# Con USE_FIREBASE_EMULATORS=true no se necesita service account.
# Arranca los emuladores antes con: firebase emulators:start
USE_FIREBASE_EMULATORS=false

FIRESTORE_EMULATOR_HOST=127.0.0.1:8010
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# ─── Firebase (emulador o producción) ────────────────────────────────────────
FIREBASE_PROJECT_ID=lenovo-experiences
FIREBASE_STORAGE_BUCKET=lenovo-experiences.firebasestorage.app

# ─── Solo producción (cuando USE_FIREBASE_EMULATORS=false) ───────────────────
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── Clave para promover administradores (primera configuración) ──────────────
# Cualquier usuario autenticado puede llamar POST /api/users/promote-admin
# enviando esta clave para convertirse en admin. Cámbiala por una cadena segura.
ADMIN_SETUP_KEY=
